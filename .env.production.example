# DentraCRM Production Environment Variables
# Auto-generated by Terraform user_data on first boot
# DB credentials are pulled from AWS SSM Parameter Store

# Database (RDS PostgreSQL - auto-populated from SSM)
DATABASE_URL=postgresql://dentacrm_admin:PASSWORD@dentacrm-prod.xxxx.ap-south-1.rds.amazonaws.com:5432/dentacrm
PLATFORM_DATABASE_URL=postgresql://dentacrm_admin:PASSWORD@dentacrm-prod.xxxx.ap-south-1.rds.amazonaws.com:5432/dentacrm

# Auth
JWT_SECRET=change-this-to-a-secure-random-string-minimum-64-characters-long
JWT_EXPIRY=24h

# Domain
FRONTEND_URL=https://magiccrm.geekzlabs.com
DOMAIN=magiccrm.geekzlabs.com

# Backup
BACKUP_S3_BUCKET=dentacrm-backups-675045716724
AWS_REGION=ap-south-1
